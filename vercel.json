{
  "buildCommand": "echo 'Frontend deployment'",
  "outputDirectory": "src/main/resources/static",
  "cleanUrls": true,
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=3600" }
      ]
    }
  ],
  "env": {
    "REACT_APP_API_URL": "@api_url"
  }
}
